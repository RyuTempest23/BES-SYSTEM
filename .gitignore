# Composer dependencies
/vendor/
composer.lock

# Configuration file with sensitive data
/config.php
.env

# Uploaded ID documents
/uploads/*.jpg
/uploads/*.png
/uploads/*.pdf
!/uploads/.gitkeep

# Logs
*.log
/logs/

# Database dumps (if you manually export)
*.sql
*.sql.gz

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.swp
*.swo

# IDE / editor files
.vscode/
.idea/
*.sublime-*
.project
.classpath

# PHP error logs
php_errors.log
error_log

# Backup files
*.bak
*.old
*.orig

# Temporary files
*.tmp
*.temp
/cache/

# Optional: ignore compiled / minified assets (if you generate any)
/assets/css/*.min.css
/assets/js/*.min.js

# Ignore PDF exports if saved temporarily
*.pdf
*.csv